{
  "name": "sourcetrace",
  "version": "0.1.0",
  "description": "Automated truth-extraction for any codebase. Reads your source and produces a structured reality map.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "sourcetrace": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "lint": "eslint src/ --ext .ts",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "developer-experience",
    "documentation",
    "code-analysis",
    "truth-extraction",
    "onboarding"
  ],
  "author": "Haley Bird",
  "license": "MIT",
  "dependencies": {
    "@typescript-eslint/parser": "^8.0.0",
    "commander": "^12.0.0",
    "fast-glob": "^3.3.0",
    "typescript": "^5.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.0.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
